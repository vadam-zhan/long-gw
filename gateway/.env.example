# long-gw .env 配置文件示例
# 使用方式: cp .env.example .env

# Gateway配置
LONG_GW_GATEWAY_ADDR=:8080
LONG_GW_GATEWAY_WORKER_NUM=100
LONG_GW_GATEWAY_MAX_CONN_NUM=1000000

# Redis配置
LONG_GW_REDIS_ADDR=localhost:6379
LONG_GW_REDIS_PASSWORD=
LONG_GW_REDIS_DB=0

# Kafka配置
LONG_GW_KAFKA_BROKERS=localhost:9092
LONG_GW_KAFKA_TOPIC=gateway-upstream

# Auth配置
LONG_GW_AUTH_ADDR=:8081

# 日志配置
LONG_GW_LOG_LEVEL=info
LONG_GW_LOG_FORMAT=console
