# long-gw 配置文件示例

gateway:
  addr: ":8080"              # 网关监听地址
  worker_num: 100             # 上行Worker池数量
  max_conn_num: 1000000      # 最大连接数
  read_buf_size: 4096         # 读缓冲区大小
  write_buf_size: 4096        # 写缓冲区大小
  profile:
    enabled: false            # pprof开关
    addr: ":8088"             # pprof监听地址
  metrics:
    enabled: false           # Prometheus监控开关
    addr: ":9090"             # metrics监听地址

redis:
  addr: "localhost:6379"     # Redis地址
  password: ""               # Redis密码
  db: 0                      # Redis数据库
  pool_size: 100              # 连接池大小
  route_ttl: 120              # 路由TTL(秒)

kafka:
  brokers:                    # Kafka集群地址
    - "localhost:9092"
  topic: "gateway-upstream"  # 默认Topic

auth:
  addr: ":8081"              # Auth服务地址

log:
  level: "info"              # 日志级别: debug/info/warn/error
  format: "console"          # 日志格式: json/console
